{
  "expo": {
    "name": "MindShift",
    "slug": "mindshift",
    "version": "1.14.0",
    "scheme": "mindshift",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#312E81"
    },
    "android": {
      "package": "com.sagearbor.mindshift.app",
      "versionCode": 29,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#312E81"
      }
    },
    "ios": {
      "bundleIdentifier": "com.sagearbor.mindshift.app",
      "buildNumber": "1"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "MindShift uses your microphone to transcribe the conversation and coach you with suggestions in real time."
        }
      ],
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "MindShift uses your camera to record a video of the conversation so you can review it later.",
          "microphonePermission": "MindShift uses your microphone to record the conversation's audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "MindShift saves your recorded videos to your camera roll so they can back up to your cloud for HD replay later.",
          "savePhotosPermission": "MindShift saves your recorded videos to your camera roll so they can back up to your cloud for HD replay later.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_WITH_IOS_CLIENT_ID"
        }
      ]
    ],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}",
      "eas": {
        "projectId": "c810a855-13ba-48bc-91f5-74f13e7b34f6"
      }
    },
    "owner": "sagearbor"
  }
}
