{
  "expo": {
    "name": "MindShift",
    "slug": "mindshift",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#312E81"
    },
    "android": {
      "package": "com.sagearbor.mindshift.app",
      "versionCode": 1,
      "permissions": ["RECORD_AUDIO"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#312E81"
      }
    },
    "ios": {
      "bundleIdentifier": "com.sagearbor.mindshift.app",
      "buildNumber": "1"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "MindShift uses your microphone to transcribe the conversation and coach you with suggestions in real time."
        }
      ]
    ],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}"
    }
  }
}
