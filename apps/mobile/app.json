{
  "expo": {
    "name": "MindShift",
    "slug": "mindshift",
    "version": "1.5.0",
    "scheme": "mindshift",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#312E81"
    },
    "android": {
      "package": "com.sagearbor.mindshift.app",
      "versionCode": 7,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#312E81"
      }
    },
    "ios": {
      "bundleIdentifier": "com.sagearbor.mindshift.app",
      "buildNumber": "1"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "MindShift uses your microphone to transcribe the conversation and coach you with suggestions in real time."
        }
      ]
    ],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}",
      "eas": {
        "projectId": "c810a855-13ba-48bc-91f5-74f13e7b34f6"
      }
    },
    "owner": "sagearbor"
  }
}
