# MindShift server configuration — COPY THIS TO .env AND FILL IN.
#
#   cp .example.env .env
#
# The server loads .env on startup (server/main.py). Real environment variables
# always take precedence over .env. With nothing set, the server still runs but
# honestly reports LLM / transcription / TTS as unavailable (it never fakes
# output) — so the two keys under REQUIRED below are what make the app actually
# work.

# ============================================================================
# REQUIRED for a working app (live coaching)
# ============================================================================

# 1) LLM — generates the coaching suggestions. Get a key at console.anthropic.com
#    (Claude 3 Haiku is cheap and is the default model). Without this the app
#    transcribes but produces NO suggestions.
ANTHROPIC_API_KEY=

# 2) Deepgram — real-time speech-to-text (and Aura TTS). console.deepgram.com
#    (You already have this locally.) Without it, transcription is unavailable
#    unless you switch to the free local Whisper provider (STT_PROVIDER=whisper).
DEEPGRAM_API_KEY=

# ============================================================================
# OPTIONAL — sensible defaults apply if unset
# ============================================================================

# LLM model (provider is inferred from the name). Default: claude-3-haiku-20240307
# MINDSHIFT_MODEL=claude-3-haiku-20240307

# Alternative LLM providers (only if you change MINDSHIFT_MODEL to their models)
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=

# Speech-to-text provider: "deepgram" (default, real-time) or "whisper"
# (free local; needs `pip install -r requirements-whisper.txt`, and is slow
# without a GPU — see the hardening report).
# STT_PROVIDER=deepgram
# WHISPER_MODEL=base

# Database file path. Default: mindshift.db at the repo root.
# NOTE for hosting: on ephemeral hosts (Cloud Run, etc.) the local file resets
# on redeploy — fine for a tester demo; use a mounted volume / managed DB later.
# MINDSHIFT_DB_PATH=mindshift.db

# ---- Deployment / hardening knobs (matter once this is hosted) -------------

# Browser Origins allowed to open the WebSocket. Native mobile apps send no
# Origin and are always allowed; a hosted WEB build must list its origin here
# (comma-separated), e.g. https://mindshift.example.web.app
# MINDSHIFT_ALLOWED_ORIGINS=

# Per-IP rate limit on the cost-bearing endpoints (/respond, /score, /export).
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60

# Log level (DEBUG|INFO|WARNING|ERROR). Default INFO.
# LOG_LEVEL=INFO

# ---- Advanced / test-only --------------------------------------------------
# Override the Deepgram live WebSocket URL (local fakes/tests only).
# DEEPGRAM_URL=
# Recognized but unimplemented TTS keys (Aura via DEEPGRAM_API_KEY is the wired path).
# TTS_API_KEY=
# ELEVENLABS_API_KEY=
# Force-refresh the on-disk LLM response cache.
# REFRESH_LLM_CACHE=
