# MindShift server configuration template.
#
# NOTE: this file is intended to live as `.env.example`; it ships as
# `env.example` only because the local agent's permission settings deny
# writing `.env.*` paths. Rename it if you like:  mv env.example .env.example
#
# Copy this file to `.env` at the repo root and uncomment/fill what you need:
#   cp env.example .env
#
# The server loads `.env` on startup (server/main.py). Real environment
# variables ALWAYS take precedence over values in .env. Every variable here
# is optional: with nothing set, the server still runs and honestly reports
# the credential-gated features (LLM, transcription, TTS) as unavailable —
# it never fabricates output.

# ----------------------------------------------------------------------------
# LLM (server/llm_client.py — provider is inferred from MINDSHIFT_MODEL)
# ----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=            # claude-* models (the default)
# OPENAI_API_KEY=               # gpt-* / o1 / o3 / o4 models
# GOOGLE_API_KEY=               # gemini-* models
# MISTRAL_API_KEY=              # mistral-* models

# Model used for suggestions/scoring/insights (default: claude-3-haiku-20240307)
# MINDSHIFT_MODEL=claude-3-haiku-20240307

# ----------------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------------
# SQLite database path (default: mindshift.db in the working directory)
# MINDSHIFT_DB_PATH=mindshift.db

# ----------------------------------------------------------------------------
# Speech-to-text (STT) provider for the real-time audio pipeline
# ----------------------------------------------------------------------------
# "deepgram" (default) — hosted live streaming STT; needs DEEPGRAM_API_KEY.
# "whisper"            — FREE local transcription via faster-whisper; no key
#                        needed, but the optional dependency must be installed:
#                          pip install -r requirements-whisper.txt
# Unknown values log a warning and fall back to deepgram.
# STT_PROVIDER=deepgram

# Deepgram API key — used for BOTH live transcription and Aura text-to-speech.
# DEEPGRAM_API_KEY=

# Override the Deepgram live WebSocket URL (tests/local fakes only).
# DEEPGRAM_URL=

# Whisper model size when STT_PROVIDER=whisper (default: base).
# tiny = fastest / least accurate · base = balanced · small = better accuracy,
# slower · medium = best practical CPU size, slow without a GPU.
# WHISPER_MODEL=base

# ----------------------------------------------------------------------------
# Text-to-speech
# ----------------------------------------------------------------------------
# Recognized but NOT implemented — only Deepgram Aura TTS (DEEPGRAM_API_KEY
# above) is wired up today. Setting these does not enable audio; they are
# documented here for honesty about what the code looks at.
# TTS_API_KEY=
# ELEVENLABS_API_KEY=

# ----------------------------------------------------------------------------
# Development
# ----------------------------------------------------------------------------
# Set to 1 to force-refresh the on-disk LLM response cache (server/llm_cache.py).
# REFRESH_LLM_CACHE=
